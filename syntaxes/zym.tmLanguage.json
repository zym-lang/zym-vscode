{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zym",
  "scopeName": "source.zym",
  "fileTypes": ["zym"],
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#compiler-directive" },
    { "include": "#struct-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#function-declaration" },
    { "include": "#goto-label" },
    { "include": "#field-designator" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#builtin-modules" },
    { "include": "#builtin-functions" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zym",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.zym" }
          }
        },
        {
          "name": "comment.block.zym",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.zym" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.zym" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.zym",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.zym" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.zym" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.zym",
          "match": "\\\\([abfnrtv0\"'\\\\]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})"
        },
        {
          "name": "constant.other.placeholder.zym",
          "match": "%[-+ #0]*\\d*(?:\\.\\d+)?[A-Za-z%]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.zym",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.zym",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.float.zym",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.zym",
          "match": "\\b\\d[\\d_]*(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.zym",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.zym",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.zym",
          "match": "\\bnull\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.zym",
          "match": "\\b(if|else|while|do|for|break|continue|return|goto|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.import.zym",
          "match": "\\b(import|from)\\b"
        },
        {
          "name": "storage.type.zym",
          "match": "\\b(var|func|struct|enum)\\b"
        },
        {
          "name": "keyword.operator.logical.zym",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spread.zym",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.assignment.compound.zym",
          "match": "(\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.increment.zym",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.comparison.zym",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.zym",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.zym",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.zym",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.zym",
          "match": "(<<|>>>|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.ternary.zym",
          "match": "[?]"
        },
        {
          "name": "keyword.operator.arrow.zym",
          "match": "=>"
        }
      ]
    },
    "function-declaration": {
      "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.function.zym" },
        "2": { "name": "entity.name.function.zym" }
      }
    },
    "struct-declaration": {
      "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.struct.zym" },
        "2": { "name": "entity.name.type.struct.zym" }
      }
    },
    "enum-declaration": {
      "begin": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\{",
      "beginCaptures": {
        "1": { "name": "storage.type.enum.zym" },
        "2": { "name": "entity.name.type.enum.zym" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comments" },
        {
          "name": "variable.other.enummember.zym",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.comma.zym",
          "match": ","
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.block.zym",
          "match": "^\\s*(##)(define|enddefine)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.zym" },
            "2": { "name": "keyword.control.directive.zym" }
          }
        },
        {
          "name": "meta.preprocessor.zym",
          "match": "^\\s*(#)(define|undef|if|ifdef|ifndef|elif|else|endif|error)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.zym" },
            "2": { "name": "keyword.control.directive.zym" }
          }
        },
        {
          "name": "support.function.preprocessor.zym",
          "match": "\\bdefined\\b"
        }
      ]
    },
    "compiler-directive": {
      "patterns": [
        {
          "match": "(@)(tco)\\s+(aggressive|safe|off)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.zym" },
            "2": { "name": "keyword.other.directive.zym" },
            "3": { "name": "constant.language.directive.mode.zym" }
          }
        },
        {
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.directive.zym" },
            "2": { "name": "keyword.other.directive.zym" }
          }
        }
      ]
    },
    "field-designator": {
      "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\s*(?==)",
      "captures": {
        "1": { "name": "punctuation.accessor.zym" },
        "2": { "name": "variable.other.property.zym" }
      }
    },
    "goto-label": {
      "patterns": [
        {
          "match": "\\b(goto)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.flow.goto.zym" },
            "2": { "name": "entity.name.label.zym" }
          }
        },
        {
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:\\s*(?://.*)?$",
          "captures": {
            "1": { "name": "entity.name.label.zym" }
          }
        }
      ]
    },
    "builtin-modules": {
      "patterns": [
        {
          "match": "\\b(Cont)(\\.)(abort|capture|isContinuation|isPromptTag|isValid|newPrompt|popPrompt|pushPrompt|resume|shift|withPrompt)\\b",
          "captures": {
            "1": { "name": "support.class.builtin.zym" },
            "2": { "name": "punctuation.accessor.zym" },
            "3": { "name": "support.function.builtin.zym" }
          }
        },
        {
          "match": "\\b(Preempt)(\\.)(disable|enable|getDisableDepth|getTimeslice|isEnabled|popDisable|pushDisable|remaining|request|reset|setCallback|setTimeslice|withDisabled|yield)\\b",
          "captures": {
            "1": { "name": "support.class.builtin.zym" },
            "2": { "name": "punctuation.accessor.zym" },
            "3": { "name": "support.function.builtin.zym" }
          }
        },
        {
          "match": "\\b(GC)(\\.)(cycle|getBytesThreshold|getBytesTracked|isPaused|pause|resume|setBytesThreshold)\\b",
          "captures": {
            "1": { "name": "support.class.builtin.zym" },
            "2": { "name": "punctuation.accessor.zym" },
            "3": { "name": "support.function.builtin.zym" }
          }
        },
        {
          "match": "\\b(Cont|Preempt|GC)\\b",
          "captures": {
            "1": { "name": "support.class.builtin.zym" }
          }
        }
      ]
    },
    "builtin-functions": {
      "match": "\\b(assert|error|typeof|num|str|length|concat|indexOf|contains|slice|push|pop|shift|unshift|insert|remove|reverse|sort|join|size|isEmpty|keys|values|entries|clear|merge|charAt|charCodeAt|byteLength|fromCodePoint|startsWith|endsWith|lastIndexOf|toUpperCase|toLowerCase|trim|trimStart|trimEnd|padStart|padEnd|repeat|replace|replaceAll|split|substr|abs|floor|ceil|round|trunc|sign|sqrt|cbrt|pow|exp|exp2|expm1|log|log10|log2|log1p|sin|cos|tan|asin|acos|atan|atan2|sinh|cosh|tanh|asinh|acosh|atanh|min|max|clamp|fmod|remainder|hypot|toRadians|toDegrees|isNaN|isInfinite|isFinite|lerp|map)\\s*(?=\\()",
      "captures": {
        "1": { "name": "support.function.builtin.zym" }
      }
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.zym" }
      }
    },
    "member-access": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "punctuation.accessor.zym" },
            "2": { "name": "entity.name.function.member.zym" }
          }
        },
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.zym" },
            "2": { "name": "variable.other.property.zym" }
          }
        }
      ]
    },
    "identifiers": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.zym"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.zym", "match": "," },
        { "name": "punctuation.terminator.statement.zym", "match": ";" },
        { "name": "punctuation.separator.colon.zym", "match": ":" }
      ]
    }
  }
}
