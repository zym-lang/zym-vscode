{
  "name": "zym-vscode",
  "displayName": "Zym for VS Code",
  "description": "Syntax highlighting, snippets and editor configuration for the Zym scripting language.",
  "version": "0.1.0",
  "publisher": "zym-lang",
  "license": "MIT",
  "author": {
    "name": "Anatole DP"
  },
  "homepage": "https://zym-lang.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zym-lang/zym-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/zym-lang/zym-vscode/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "zym",
    "scripting",
    "language"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zym",
        "aliases": [
          "Zym",
          "zym"
        ],
        "extensions": [
          ".zym"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zym",
        "scopeName": "source.zym",
        "path": "./syntaxes/zym.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zym",
        "path": "./snippets/zym.json"
      }
    ]
  }
}
